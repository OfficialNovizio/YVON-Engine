#!/usr/bin/env bash
# yvon-doctor — Full health check for YVON Engine + project
# Usage: bash tools/yvon-doctor [--fix]

set -euo pipefail
ROOT="${1:-.}"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

pass=0; fail=0; warn=0
ok()  { echo -e "  ${GREEN}✅${NC} $1: $2"; ((pass++)); }
err() { echo -e "  ${RED}❌${NC} $1: $2"; ((fail++)); }
wrn() { echo -e "  ${YELLOW}⚠️${NC} $1: $2"; ((warn++)); }

echo ""
echo "  🏥 YVON Engine — Health Check"
echo "  $(date '+%Y-%m-%d %H:%M')"
echo ""

# ── Engine package ──────────────────────────────────────────────────────
ENGINE_PKG="$ROOT/node_modules/yvon-engine/package.json"
if [ -f "$ENGINE_PKG" ]; then
  VER=$(node -e "console.log(require('$ENGINE_PKG').version)" 2>/dev/null || echo "?")
  ok "yvon-engine" "v$VER"
else
  err "yvon-engine" "not installed — run: npm install yvon-engine"
fi

# ── .toon/ structure ────────────────────────────────────────────────────
TOON_DIR="$ROOT/.toon"
if [ -d "$TOON_DIR" ]; then
  DOCS=$(find "$TOON_DIR/docs" -type f 2>/dev/null | wc -l)
  MEMS=$(find "$TOON_DIR/memory" -type f 2>/dev/null | wc -l)
  ok ".toon/"     "docs:$DOCS memory:$MEMS"
else
  wrn ".toon/"    "not found — run: npx yvon integrate"
fi

# ── V3 engine.bin ───────────────────────────────────────────────────────
ENGINE_BIN="$TOON_DIR/v3/engine.bin"
if [ -f "$ENGINE_BIN" ]; then
  SIZE=$(du -h "$ENGINE_BIN" | cut -f1)
  CHUNKS=$(node -e "try{const d=JSON.parse(require('fs').readFileSync('$ENGINE_BIN','utf-8'));console.log(d.chunkCount)}catch(e){console.log('?')}" 2>/dev/null)
  ok  "engine.bin" "$SIZE, $CHUNKS chunks"
else
  wrn "engine.bin" "not compiled — run: npx yvon integrate"
fi

# ── Schemas ─────────────────────────────────────────────────────────────
SCHEMAS="$TOON_DIR/schemas.toon"
if [ -f "$SCHEMAS" ]; then
  SIZE=$(du -h "$SCHEMAS" | cut -f1)
  ok  "schemas.toon" "$SIZE"
else
  wrn "schemas.toon" "not generated"
fi

# ── Dictionary ──────────────────────────────────────────────────────────
DICT="$TOON_DIR/dictionary.toon"
if [ -f "$DICT" ]; then
  TERMS=$(grep -c "DICT" "$DICT" 2>/dev/null || echo "?")
  ok  "dictionary" "$TERMS term groups"
else
  wrn "dictionary" "not generated"
fi

# ── Archive ─────────────────────────────────────────────────────────────
ARCHIVE="$TOON_DIR/.archive"
if [ -d "$ARCHIVE" ]; then
  SNAPS=$(ls "$ARCHIVE" 2>/dev/null | wc -l)
  ok  ".archive"   "$SNAPS rollback snapshots"
else
  wrn ".archive"   "no rollback available"
fi

# ── Graphs ──────────────────────────────────────────────────────────────
if [ -d "$ROOT/graphify-out" ] || [ -d "$TOON_DIR/graphs" ]; then
  ok  "graphs"     "available"
else
  wrn "graphs"     "not built — run: npx yvon graph"
fi

# ── CIE wiring ──────────────────────────────────────────────────────────
CLAUDE_RT="$ROOT/app/api/claude/route.ts"
if [ -f "$CLAUDE_RT" ]; then
  if grep -q "yvon-engine" "$CLAUDE_RT" 2>/dev/null; then
    ok "CIE/TOON"  "wired in Claude route"
  else
    wrn "CIE/TOON" "not wired — run: npx yvon integrate"
  fi
fi

# ── Build check ─────────────────────────────────────────────────────────
if [ -f "$ROOT/package.json" ]; then
  if [ -d "$ROOT/.next" ]; then
    ok  "build"      ".next/ exists"
  else
    wrn "build"      "not built — run: npm run build"
  fi
fi

# ── Summary ─────────────────────────────────────────────────────────────
echo ""
echo "  ─────────────────────────────"
echo -e "  ${GREEN}Pass: $pass${NC}  ${RED}Fail: $fail${NC}  ${YELLOW}Warn: $warn${NC}"
echo ""

if [ "$fail" -gt 0 ]; then
  echo "  Run: npx yvon integrate   (fix wiring)"
  echo "  Run: npx yvon doctor      (interactive)"
  exit 1
elif [ "$warn" -gt 0 ]; then
  echo "  Run: npx yvon integrate   (one-click fix)"
  exit 0
else
  echo "  ✅ All systems operational"
  exit 0
fi
