#!/usr/bin/env bash
# yvon-sync — Bidirectional sync: .toon/ ↔ originals
# Watches for changes and keeps both versions in sync.
# Usage: bash tools/yvon-sync [--watch] [--once]

set -euo pipefail
ROOT="${1:-.}"
MODE="${2:---once}"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

sync_file() {
  local ORIG="$1"
  local TOON="$2"
  local REL="${3:-unknown}"

  if [ ! -f "$ORIG" ]; then
    # Original deleted → remove TOON too
    rm -f "$TOON" 2>/dev/null
    return
  fi

  # Check if TOON needs update (older than original)
  if [ -f "$TOON" ] && [ "$TOON" -nt "$ORIG" ]; then
    return  # TOON is newer — nothing to do
  fi

  # Compress original → TOON
  mkdir -p "$(dirname "$TOON")" 2>/dev/null
  node -e "
    const fs=require('fs');
    try {
      const c=fs.readFileSync('$ORIG','utf-8');
      const stripped=c.replace(/#{1,6}\s+/g,'§').replace(/\\*\\*/g,'').replace(/\\n{3,}/g,'\\n\\n').replace(/\`\`\`[\s\S]*?\`\`\`/g,'[CODE]');
      fs.writeFileSync('$TOON','#TOON src=$REL synced='+new Date().toISOString()+'\\n'+stripped.slice(0,50000));
    } catch(e) { /* skip unreadable files */ }
  " 2>/dev/null || true

  echo "  $(date +%H:%M:%S) synced: $REL"
}

sync_all() {
  local count=0
  echo ""
  echo "  🔄 YVON Sync — $(date '+%Y-%m-%d %H:%M:%S')"
  echo ""

  # Sync agent-department → .toon/memory/
  if [ -d "$ROOT/agent-department" ]; then
    while IFS= read -r -d '' f; do
      rel="${f#$ROOT/}"
      toon="$ROOT/.toon/memory/${rel%.md}.toon"
      sync_file "$f" "$toon" "$rel"
      ((count++))
    done < <(find "$ROOT/agent-department" -name "*.md" -print0 2>/dev/null)
  fi

  # Sync agent-memory → .toon/memory/
  if [ -d "$ROOT/agent-memory" ]; then
    while IFS= read -r -d '' f; do
      rel="${f#$ROOT/}"
      toon="$ROOT/.toon/memory/${rel%.md}.toon"
      sync_file "$f" "$toon" "$rel"
      ((count++))
    done < <(find "$ROOT/agent-memory" -name "*.md" -print0 2>/dev/null)
  fi

  # Sync docs → .toon/docs/
  if [ -d "$ROOT/docs" ]; then
    while IFS= read -r -d '' f; do
      rel="${f#$ROOT/}"
      toon="$ROOT/.toon/docs/${rel%.md}.toon"
      sync_file "$f" "$toon" "$rel"
      ((count++))
    done < <(find "$ROOT/docs" -name "*.md" -print0 2>/dev/null)
  fi

  # Sync CLAUDE.md → .toon/project/
  if [ -f "$ROOT/CLAUDE.md" ]; then
    mkdir -p "$ROOT/.toon/project"
    sync_file "$ROOT/CLAUDE.md" "$ROOT/.toon/project/CLAUDE.md" "CLAUDE.md"
    ((count++))
  fi

  echo ""
  echo -e "  ${GREEN}✅ $count files synced${NC}"
}

if [ "$MODE" = "--watch" ]; then
  echo "  👁️  Watching for changes... (Ctrl+C to stop)"
  sync_all
  # Watch using inotify/fswatch if available
  if command -v fswatch &>/dev/null; then
    fswatch -0 "$ROOT/agent-department" "$ROOT/agent-memory" "$ROOT/docs" "$ROOT/CLAUDE.md" 2>/dev/null | while read -r -d '' f; do
      sync_all
    done
  else
    # Fallback: poll every 30s
    while true; do sleep 30; sync_all; done
  fi
else
  sync_all
fi
