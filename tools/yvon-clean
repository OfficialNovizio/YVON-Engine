#!/usr/bin/env bash
# yvon-clean — Remove stale duplicates, rebuild engine.bin index
# Usage: bash tools/yvon-clean

set -euo pipefail
ROOT="${1:-.}"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
TOON_DIR="$ROOT/.toon"

echo ""
echo "  🧹 YVON Cleaner"
echo ""

# ── 1. Remove empty directories ─────────────────────────────────────────
EMPTY=$(find "$TOON_DIR" -type d -empty 2>/dev/null | wc -l)
if [ "$EMPTY" -gt 0 ]; then
  find "$TOON_DIR" -type d -empty -delete 2>/dev/null
  echo -e "  ${GREEN}🧹${NC} Removed $EMPTY empty directories"
fi

# ── 2. Deduplicate agent-memory vs agent-department ──────────────────────
MEM_DIR="$TOON_DIR/memory"
if [ -d "$MEM_DIR/agent-department" ] && [ -d "$MEM_DIR/agent-memory" ]; then
  echo ""
  echo "  ⚠️  Both agent-department/ and agent-memory/ exist under .toon/memory/"
  echo "  Checking for duplicates..."
  
  DUPES=$(find "$MEM_DIR/agent-memory" -name "*.toon" -exec sh -c '
    f="$1"
    dep="${f/agent-memory/agent-department}"
    [ -f "$dep" ] && echo "$f"
  ' _ {} \; 2>/dev/null | wc -l)
  
  if [ "$DUPES" -gt 0 ]; then
    echo -e "  ${YELLOW}Found $DUPES duplicate files${NC}"
    echo "  Run: rm -rf $MEM_DIR/agent-memory   (if agent-department is canonical)"
  else
    echo "  No duplicates — both contain unique files"
  fi
fi

# ── 3. Rebuild engine.bin ───────────────────────────────────────────────
echo ""
echo "  🧠 Rebuilding v3 engine.bin..."
node -e "
  try {
    const {compile} = require('$ROOT/node_modules/yvon-engine/dist/toon/v3/compile');
    const result = compile({projectRoot:'$ROOT',maxMergeIterations:512});
    console.log('  ✅ engine.bin: '+result.chunkCount+' chunks · '+result.indexSize+' terms · '+result.bpeTokens+' BPE tokens');
  } catch(e) {
    console.log('  ⚠️  Compile failed: '+e.message);
    console.log('  Run: npm install yvon-engine first');
  }
" 2>/dev/null || echo "  ⚠️  engine not installed — run: npm install yvon-engine"

echo ""
echo -e "  ${GREEN}✅ Clean complete${NC}"
echo ""
