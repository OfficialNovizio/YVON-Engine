#!/usr/bin/env bash
# yvon-graph — Rebuild all knowledge graphs + absorb into .toon/graphs/
# Usage: bash tools/yvon-graph [--rebuild] [--dry-run]

set -euo pipefail
ROOT="${1:-.}"
DRY="${2:-}"

echo ""
echo "  🧠 YVON Graph Builder"
echo "  $(date '+%Y-%m-%d %H:%M')"
echo ""

# ── Detect available graph tools ────────────────────────────────────────
HAS_GRAPHIFY=false
HAS_CODEGRAPH=false
HAS_CODE_REVIEW_GRAPH=false
HAS_BUILTIN=true

if command -v graphify &>/dev/null; then HAS_GRAPHIFY=true; fi
if command -v codegraph &>/dev/null; then HAS_CODEGRAPH=true; fi
if command -v code-review-graph &>/dev/null; then HAS_CODE_REVIEW_GRAPH=true; fi

echo "  Detected:"
echo "    graphify:          $HAS_GRAPHIFY"
echo "    codegraph:         $HAS_CODEGRAPH"
echo "    code-review-graph: $HAS_CODE_REVIEW_GRAPH"
echo "    builtin (regex):   $HAS_BUILTIN  (always available)"
echo ""

# ── Run graphify ────────────────────────────────────────────────────────
if $HAS_GRAPHIFY; then
  echo "  📊 Running: graphify update ."
  if [ "$DRY" != "--dry-run" ]; then
    cd "$ROOT" && graphify update . 2>&1 | tail -3 || echo "  ⚠️  graphify failed — skipping"
  fi
fi

# ── Run code-review-graph (Tree-sitter) ──────────────────────────────────
if $HAS_CODE_REVIEW_GRAPH; then
  echo "  🔬 Running: code-review-graph build"
  if [ "$DRY" != "--dry-run" ]; then
    cd "$ROOT" && code-review-graph build 2>&1 | tail -3 || echo "  ⚠️  code-review-graph failed — skipping"
  fi
fi

# ── Run builtin graph builder ───────────────────────────────────────────
echo "  🏗️  Running: builtin graph builder (npx yvon graph)"
if [ "$DRY" != "--dry-run" ]; then
  cd "$ROOT" && npx yvon graph 2>&1 | tail -5
fi

# ── Absorb graph output into .toon/graphs/ ──────────────────────────────
TOON_GRAPHS="$ROOT/.toon/graphs"
mkdir -p "$TOON_GRAPHS"

if [ -d "$ROOT/graphify-out" ]; then
  echo "  📦 Absorbing graphify output → .toon/graphs/"
  if [ "$DRY" != "--dry-run" ]; then
    for f in "$ROOT/graphify-out"/*.md "$ROOT/graphify-out"/*.json; do
      [ -f "$f" ] || continue
      name=$(basename "$f")
      if [ "${name##*.}" = "md" ]; then
        # Strip markdown → TOON format
        node -e "
          const fs=require('fs');
          const c=fs.readFileSync('$f','utf-8');
          const stripped=c.replace(/#{1,6}\s+/g,'').replace(/\*\*/g,'').replace(/```[\s\S]*?```/g,'[CODE]').replace(/\|/g,' ').replace(/\n{3,}/g,'\n\n');
          fs.writeFileSync('$TOON_GRAPHS/${name%.md}.toon','#GRAPH source=${name}\n'+stripped.slice(0,50000));
        " 2>/dev/null
      else
        cp "$f" "$TOON_GRAPHS/$name" 2>/dev/null
      fi
    done
    echo "    → $(ls "$TOON_GRAPHS" 2>/dev/null | wc -l) files"
  fi
fi

# ── Summary ─────────────────────────────────────────────────────────────
echo ""
if [ "$DRY" = "--dry-run" ]; then
  echo "  🔍 Dry run complete — no changes made"
  echo "  Run without --dry-run to apply"
else
  echo "  ✅ Graphs rebuilt + absorbed into .toon/graphs/"
  echo "  Run: npx yvon integrate   (re-index engine.bin with new graphs)"
fi
echo ""
