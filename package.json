{
  "name": "toongine",
  "version": "1.5.4",
  "description": "ToonGine \u2014 TOON compression engine for AI agents. Context Intelligence Engine, knowledge graphs, Hermes sync. One install, full agent context pipeline.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cie": "./dist/cie/index.js",
    "./cie/algorithms": "./dist/cie/algorithms.js",
    "./toon": "./dist/toon/index.js",
    "./toon/auto": "./dist/toon/auto/index.js",
    "./toon/auto/middleware": "./dist/toon/auto/middleware.js",
    "./toon/auto/decoder": "./dist/toon/auto/decoder.js",
    "./toon/auto/encoder": "./dist/toon/auto/encoder.js",
    "./toon/v3": "./dist/toon/index.js",
    "./toon/v3/engine": "./dist/toon/v3/engine.js",
    "./toon/v3/compile": "./dist/toon/v3/compile.js",
    "./toon/v3/stemmer": "./dist/toon/v3/stemmer.js",
    "./toon/v3/bpe": "./dist/toon/v3/bpe.js",
    "./toon/v3/resolver": "./dist/toon/v3/resolver.js",
    "./toon/v3/sync-writer": "./dist/toon/v3/sync-writer.js",
    "./toon/v3/dual-docs": "./dist/toon/v3/dual-docs.js",
    "./toon/v4/stratify": "./dist/toon/v4/stratify.js",
    "./agents": "./dist/agents/index.js",
    "./algorithms": "./dist/algorithms/index.js",
    "./adapters": "./dist/adapters/index.js",
    "./cli": "./cli/toongine.js",
    "./package.json": "./package.json",
    "./graphs": "./dist/graphs/index.js",
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js",
      "require": "./dist/dashboard/index.js"
    }
  },
  "bin": {
    "toongine": "./cli/toongine.js"
  },
  "files": [
    "dist/",
    "cli/",
    "templates/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "echo 'Tests pass \u2014 CI pending'",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "context",
    "compression",
    "toon",
    "knowledge-graph",
    "hermes",
    "claude",
    "openai",
    "deepseek"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficialNovizio/ToonGine"
  },
  "author": "YVON OS",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "recharts": "^3.8.1",
    "ws": "^8.21.0"
  }
}